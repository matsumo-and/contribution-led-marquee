{
  "name": "dog-rpg-action",
  "version": "1.0.0",
  "description": "GitHub Action that generates a Dog RPG visualization from GitHub Contribution Graph",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package": "ncc build dist/index.js -o dist/compiled",
    "dev": "ts-node src/index.ts",
    "test": "ts-node src/test.ts"
  },
  "keywords": ["github-action", "contribution-graph", "rpg", "visualization"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}